# 服务端口
PORT=3000

# Node环境
NODE_ENV=development

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# MongoDB连接字符串
MONGODB_URI=mongodb://localhost:27017/dada

# 微信小程序配置
WX_APPID=your_wx_appid_here
WX_SECRET=your_wx_secret_here

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
CREATE_RATE_LIMIT_WINDOW_MS=3600000
CREATE_RATE_LIMIT_MAX=20
APPLY_RATE_LIMIT_WINDOW_MS=3600000
APPLY_RATE_LIMIT_MAX=30
