.container {
  min-height: 100vh;
  background-color: #f5f7fa;
}

.record-list {
  height: 100vh;
  overflow-y: auto;
}

.record-card {
  margin: 24rpx;
  transition: all 0.3s;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
}

.record-status {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-success {
  background-color: rgba(52, 199, 89, 0.1);
  color: #34c759;
}

.status-fail {
  background-color: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

.status-pending {
  background-color: rgba(255, 149, 0, 0.1);
  color: #ff9500;
}

.record-info {
  margin-bottom: 16rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.info-label {
  color: #999;
}
