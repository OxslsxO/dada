.container {
  min-height: 100vh;
  background-color: var(--background-color);
}

.message-list {
  min-height: 100vh;
  overflow-y: auto;
  padding-bottom: 24rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx;
  background-color: white;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow);
  transition: all 0.3s;
  animation: fadeIn 0.5s ease-in-out;
}

.message-item:active {
  background-color: rgba(30, 92, 70, 0.05);
  transform: scale(0.98);
}

.message-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 48rpx;
  text-align: center;
  padding-top: 4rpx;
  color: var(--primary-color);
}

.message-content {
  flex: 1;
}

.message-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.message-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.message-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.message-badge {
  width: 14rpx;
  height: 14rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  margin-left: 16rpx;
  margin-top: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(30, 92, 70, 0.3);
}
