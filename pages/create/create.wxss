.container {
  padding: 24rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.form {
  background-color: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #666;
}

.textarea {
  width: 100%;
  height: 160rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  resize: none;
}

.number-input {
  display: flex;
  align-items: center;
}

.number {
  flex: 1;
}

.btn {
  margin-top: 32rpx;
}

/* 标签选择器样式 */
.tag-selector {
  margin-bottom: 20rpx;
}

.preset-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background-color: #f5f7fa;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
  transition: all 0.3s ease;
}

.tag-item.active {
  background: linear-gradient(135deg, #ff9a8b 0%, #ff6a88 100%);
  color: #fff;
  border-color: #ff9a8b;
  box-shadow: 0 2rpx 8rpx rgba(255, 106, 136, 0.3);
}

.custom-tag-input {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.tag-input {
  flex: 1;
}

.add-tag-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #ff9a8b 0%, #ff6a88 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 26rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.add-tag-btn:active {
  transform: scale(0.96);
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.selected-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #ff9a8b 0%, #ff6a88 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.remove-tag {
  font-size: 28rpx;
  line-height: 1;
  opacity: 0.8;
}

/* 位置选择器样式 */
.location-selector {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-btn {
  width: 100%;
  background-color: #f5f7fa;
  color: #333;
  border: 1rpx dashed #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s ease;
}

.location-btn:active {
  background-color: rgba(255, 106, 136, 0.1);
  transform: scale(0.98);
}

.location-info {
  background-color: #f8f9fb;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.location-address {
  font-size: 24rpx;
  color: #666;
}

.location-input {
  margin-top: 8rpx;
}

