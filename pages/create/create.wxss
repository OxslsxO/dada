.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  background: var(--background-color);
  box-sizing: border-box;
}

.form {
  padding: 32rpx;
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  background: var(--cream-gradient);
  box-shadow: var(--shadow);
}

.form-item {
  margin-bottom: 34rpx;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.label-row .label {
  margin-bottom: 0;
}

.label-tip,
.member-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.member-count {
  font-weight: 700;
  color: var(--primary-dark);
}

.input,
.textarea,
.picker-field {
  width: 100%;
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  background: rgba(255, 252, 246, 0.86);
  box-sizing: border-box;
  color: var(--text-primary);
}

.input {
  height: 92rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.textarea {
  height: 180rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.textarea-small {
  height: 140rpx;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  min-height: 62rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(70, 106, 82, 0.24);
  border-radius: 999rpx;
  background: #fffdf8;
  color: #223127;
  font-size: 25rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.chip.active {
  border-color: #223127;
  background: #223127;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(34, 49, 39, 0.22);
}

.chip-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #f2a65a;
  color: #223127;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  font-weight: 800;
}

.tag-preset {
  margin-bottom: 20rpx;
}

.tag-chip {
  min-height: 56rpx;
  font-size: 24rpx;
}

.custom-tag-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-input {
  flex: 1;
}

.add-tag-btn {
  height: 92rpx;
  min-width: 116rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: var(--accent-gradient);
  color: #fffaf3;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.selected-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(70, 106, 82, 0.1);
  color: var(--primary-dark);
  font-size: 24rpx;
}

.remove-tag {
  font-size: 30rpx;
  line-height: 1;
  color: var(--text-secondary);
}

.empty-tip {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.member-slider {
  margin: 2rpx 0 0;
}

.slider-scale {
  display: flex;
  justify-content: space-between;
  padding: 0 4rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.time-range {
  display: grid;
  grid-template-columns: 1fr 28rpx 1fr;
  align-items: stretch;
  gap: 12rpx;
}

.time-range.single {
  grid-template-columns: 1fr;
}

.time-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.time-group {
  min-width: 0;
}

.time-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #223127;
}

.time-picker-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.time-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.time-modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 80;
  background: rgba(34, 49, 39, 0.36);
}

.time-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 81;
  padding: 30rpx 28rpx 42rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: #fffdf8;
  box-shadow: 0 -16rpx 44rpx rgba(34, 49, 39, 0.18);
  box-sizing: border-box;
}

.time-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #223127;
}

.time-modal-close {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.time-modal-desc {
  display: block;
  margin: 10rpx 0 22rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.modal-row {
  margin-bottom: 24rpx;
}

.time-modal-btn {
  margin-top: 0;
}

.picker-field {
  min-height: 92rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.field-value,
.field-placeholder {
  font-size: 24rpx;
  line-height: 1.25;
  word-break: break-all;
}

.field-value {
  color: var(--text-primary);
}

.field-placeholder {
  color: var(--text-light);
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item,
.upload-card {
  position: relative;
  height: 190rpx;
  aspect-ratio: 1 / 1;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: rgba(255, 252, 246, 0.78);
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(34, 49, 39, 0.72);
  color: #fff;
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
}

.upload-card {
  border: 1rpx dashed var(--border-strong);
  color: var(--text-secondary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-plus {
  font-size: 48rpx;
  line-height: 1;
  color: var(--primary-color);
}

.upload-text {
  font-size: 24rpx;
}

.location-selector {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.location-btn {
  width: 100%;
  height: 92rpx;
  border: 1rpx dashed var(--border-strong);
  border-radius: var(--radius-md);
  background: rgba(255, 252, 246, 0.78);
  color: var(--primary-dark);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.location-btn::after {
  border: none;
}

.location-info {
  padding: 20rpx 22rpx;
  border-radius: var(--radius-md);
  background: rgba(70, 106, 82, 0.08);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.location-address {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.btn {
  margin-top: 38rpx;
}

.phone-modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 90;
  background: rgba(34, 49, 39, 0.38);
}

.phone-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  z-index: 91;
  padding: 40rpx 34rpx;
  border-radius: 28rpx;
  background: #fffdf8;
  transform: translateY(-50%);
  box-shadow: 0 20rpx 60rpx rgba(34, 49, 39, 0.2);
  box-sizing: border-box;
}

.phone-modal-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #223127;
  text-align: center;
}

.phone-modal-desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  text-align: center;
}

.phone-modal-btn {
  margin-top: 34rpx;
}

.phone-modal-cancel {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--text-light);
  text-align: center;
}
