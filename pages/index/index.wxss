.discover-page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 24rpx 156rpx;
  box-sizing: border-box;
}

.top-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(24rpx);
  opacity: 0.72;
  pointer-events: none;
}

.top-glow-left {
  top: 40rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(242, 166, 90, 0.18);
}

.top-glow-right {
  top: 120rpx;
  right: -50rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(112, 144, 119, 0.16);
}

.hero-shell {
  position: relative;
  z-index: 2;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: calc(var(--status-bar-height) + 8rpx);
  margin-bottom: 16rpx;
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f1be83 0%, #df9152 100%);
  box-shadow: 0 14rpx 24rpx rgba(223, 145, 82, 0.24);
  color: #fffaf2;
  font-size: 34rpx;
  font-weight: 800;
}

.brand-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
}

.brand-tagline {
  font-size: 20rpx;
  color: var(--text-light);
  line-height: 1.3;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.notification-container,
.capsule-btn {
  height: 68rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 245, 0.72);
  border: 1rpx solid rgba(83, 112, 88, 0.08);
  box-shadow: 0 12rpx 24rpx rgba(63, 52, 31, 0.08);
}

.notification-container {
  width: 68rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  color: var(--primary-color);
  font-size: 26rpx;
}

.notification-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f19a52;
}

.capsule-btn {
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.capsule-icon {
  color: var(--primary-color);
  font-size: 24rpx;
}

.capsule-divider {
  width: 1rpx;
  height: 22rpx;
  background: rgba(83, 112, 88, 0.12);
}

.tab-scroll-container {
  position: sticky;
  top: calc(var(--status-bar-height) + 8rpx);
  z-index: 15;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
  margin-bottom: 8rpx;
  padding: 6rpx 0 14rpx;
  background: linear-gradient(180deg, rgba(247, 240, 230, 0.98) 0%, rgba(247, 240, 230, 0.86) 100%);
  backdrop-filter: blur(16rpx);
}

.tab-scroll {
  flex: 1;
  min-width: 0;
}

.tab-container {
  display: flex;
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(228, 221, 211, 0.54);
  box-shadow: inset 0 1rpx 1rpx rgba(255, 255, 255, 0.36);
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: transparent;
  border: 1rpx solid transparent;
  color: #68756d;
  font-size: 23rpx;
  font-weight: 500;
  line-height: 1;
  letter-spacing: 0.2rpx;
}

.tab-item.active {
  background: rgba(255, 253, 249, 0.96);
  color: #2f4a38;
  border-color: rgba(255, 255, 255, 0.72);
  box-shadow: 0 6rpx 14rpx rgba(89, 74, 44, 0.08);
}

.filter-tab-fixed {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 253, 249, 0.88);
  border: 1rpx solid rgba(83, 112, 88, 0.08);
  box-shadow: 0 8rpx 16rpx rgba(63, 52, 31, 0.05);
}

.filter-tab-fixed.is-active {
  background: rgba(242, 166, 90, 0.14);
}

.filter-icon-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #435448;
}

.active-filter-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 4rpx 0 18rpx;
}

.active-filter-chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(70, 106, 82, 0.1);
  color: var(--primary-color);
  font-size: 22rpx;
  line-height: 1;
}

.filter-overlay {
  position: fixed;
  inset: 0;
  background: rgba(31, 35, 31, 0.24);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
  z-index: 18;
}

.filter-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.filter-section-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 19;
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.filter-section-container.expanded {
  transform: translateY(0);
}

.filter-content {
  max-height: 75vh;
  padding: 30rpx 24rpx calc(env(safe-area-inset-bottom) + 30rpx);
  border-radius: 42rpx 42rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 250, 242, 0.98) 0%, rgba(245, 237, 225, 0.98) 100%);
  box-shadow: 0 -20rpx 48rpx rgba(40, 36, 27, 0.12);
  backdrop-filter: blur(18rpx);
  overflow-y: auto;
}

.filter-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.filter-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.filter-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-light);
}

.filter-toggle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.64);
  color: var(--text-secondary);
  font-size: 34rpx;
}

.filter-section {
  margin-top: 28rpx;
}

.section-label {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 246, 0.82);
  border: 1rpx solid rgba(83, 112, 88, 0.08);
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1;
}

.option-item.active {
  background: linear-gradient(135deg, #5f8763 0%, #45694f 100%);
  color: #f8f6ef;
  border-color: transparent;
}

.custom-time {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 245, 0.8);
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.time-picker-row + .time-picker-row {
  margin-top: 16rpx;
}

.time-label {
  width: 72rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

.time-picker {
  flex: 1;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(250, 244, 235, 0.9);
  color: var(--text-primary);
  font-size: 24rpx;
  text-align: right;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.filter-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.filter-btn::after {
  border: none;
}

.reset-btn {
  background: rgba(255, 252, 246, 0.76);
  color: var(--text-secondary);
  border: 1rpx solid rgba(83, 112, 88, 0.12);
}

.confirm-btn {
  background: linear-gradient(135deg, #5f8763 0%, #45694f 100%);
  color: #fffaf3;
  box-shadow: 0 14rpx 28rpx rgba(63, 97, 72, 0.22);
}

.activity-container {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  margin-top: 6rpx;
}

.activity-card {
  border-radius: 38rpx;
  background: rgba(255, 252, 246, 0.88);
  border: 1rpx solid rgba(83, 112, 88, 0.08);
  box-shadow: 0 20rpx 44rpx rgba(63, 52, 31, 0.08);
  overflow: hidden;
}

.card-image-wrap {
  position: relative;
  height: 360rpx;
}

.card-image {
  width: 100%;
  height: 100%;
}

.image-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(26, 28, 25, 0.04) 0%, rgba(26, 28, 25, 0.28) 100%);
}

.card-type-tag,
.card-badge {
  position: absolute;
  top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  z-index: 2;
}

.card-type-tag {
  left: 22rpx;
  color: #fffaf2;
  background: rgba(34, 49, 39, 0.42);
  backdrop-filter: blur(12rpx);
}

.card-badge {
  right: 22rpx;
  color: #915520;
  background: rgba(247, 212, 165, 0.92);
}

.card-body {
  padding: 28rpx 26rpx;
}

.card-heading {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.28;
  color: var(--text-primary);
}

.card-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(244, 239, 231, 0.92);
  color: var(--text-secondary);
}

.meta-pill-icon {
  font-size: 20rpx;
  color: var(--primary-color);
}

.meta-pill-text {
  font-size: 22rpx;
  line-height: 1;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.scene-tag {
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(70, 106, 82, 0.08);
  color: var(--primary-color);
  font-size: 20rpx;
  line-height: 1;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(83, 112, 88, 0.08);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.user-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.user-role {
  font-size: 20rpx;
  color: var(--text-light);
}

.join-btn {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f4b36f 0%, #de9150 100%);
  box-shadow: 0 12rpx 20rpx rgba(223, 143, 73, 0.22);
  color: #fffaf3;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}
