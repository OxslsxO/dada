.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 24rpx;
}

.card {
  background-color: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.form {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.textarea {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  resize: none;
}
