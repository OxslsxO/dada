<view class="container">
  <view wx:if="{{step === 'login'}}" class="login-container fade-in">
    <view class="logo">搭搭</view>
    <view class="slogan">先完成微信登录，再开始寻找同城搭子</view>
    <button class="btn btn-primary" bindtap="wechatLogin">微信快捷登录</button>
  </view>

  <view wx:if="{{step === 'bindPhone'}}" class="bind-container fade-in">
    <view class="title">绑定手机号</view>
    <view class="form">
      <view class="phone-card">
        <text class="phone-title">使用微信绑定的手机号</text>
        <text class="phone-desc">用于报名通知和账号安全，不会公开展示。</text>
      </view>
      <button
        wx:if="{{!privacyAgreed}}"
        class="btn btn-primary mt-2"
        open-type="agreePrivacyAuthorization"
        bindagreeprivacyauthorization="onAgreePrivacy"
      >
        同意隐私协议并继续
      </button>
      <button
        wx:else
        class="btn btn-primary mt-2"
        open-type="getPhoneNumber"
        bindgetphonenumber="bindWechatPhone"
        loading="{{isBindingPhone}}"
        disabled="{{isBindingPhone}}"
      >
        一键绑定手机号
      </button>
    </view>
  </view>

  <view wx:if="{{step === 'authenticate'}}" class="auth-container fade-in">
    <view class="title">身份验证</view>
    <view class="form">
      <view class="form-item">
        <text class="label">真实姓名</text>
        <input
          class="input"
          placeholder="请输入真实姓名"
          bindinput="bindNameInput"
          value="{{name}}"
        />
      </view>
      <view class="form-item">
        <text class="label">身份证号</text>
        <input
          class="input"
          placeholder="请输入身份证号"
          bindinput="bindIdCardInput"
          value="{{idCard}}"
        />
      </view>
      <button class="btn btn-primary mt-2" bindtap="submitAuth">提交验证</button>
    </view>
    <view class="tip">
      身份信息仅用于实名认证，我们会严格保护你的隐私。
    </view>
  </view>
</view>
