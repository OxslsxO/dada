<view class="container">
  <!-- 登录页面 -->
  <view wx:if="{{step === 'login'}}" class="login-container fade-in">
    <view class="logo">搭哒</view>
    <view class="slogan">找到志同道合的搭子</view>
    <button class="btn btn-primary" bindtap="wechatLogin">微信快捷登录</button>
  </view>

  <!-- 手机号绑定页面 -->
  <view wx:if="{{step === 'bindPhone'}}" class="bind-container fade-in">
    <view class="title">绑定手机号</view>
    <view class="form">
      <view class="form-item">
        <text class="label">手机号</text>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入手机号" 
          bindinput="bindPhoneInput"
          value="{{phone}}"
        />
      </view>
      <view class="form-item">
        <text class="label">验证码</text>
        <view class="code-input">
          <input 
            class="input code" 
            type="number" 
            placeholder="请输入验证码" 
            bindinput="bindCodeInput"
            value="{{code}}"
          />
          <button class="btn btn-secondary code-btn" bindtap="sendCode" disabled="{{countdown > 0}}">
            {{countdown > 0 ? countdown + 's' : '发送验证码'}}
          </button>
        </view>
      </view>
      <button class="btn btn-primary mt-2" bindtap="submitPhone">绑定手机号</button>
    </view>
  </view>

  <!-- 身份验证页面 -->
  <view wx:if="{{step === 'authenticate'}}" class="auth-container fade-in">
    <view class="title">身份验证</view>
    <view class="form">
      <view class="form-item">
        <text class="label">真实姓名</text>
        <input 
          class="input" 
          placeholder="请输入真实姓名" 
          bindinput="bindNameInput"
          value="{{name}}"
        />
      </view>
      <view class="form-item">
        <text class="label">身份证号</text>
        <input 
          class="input" 
          placeholder="请输入身份证号" 
          bindinput="bindIdCardInput"
          value="{{idCard}}"
        />
      </view>
      <button class="btn btn-primary mt-2" bindtap="submitAuth">提交验证</button>
    </view>
    <view class="tip">
      身份信息仅用于实名认证，我们会严格保护您的隐私
    </view>
  </view>
</view>
