.detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  min-height: 520rpx;
  border-radius: 42rpx;
  overflow: hidden;
  background: #ddd;
  box-shadow: 0 24rpx 52rpx rgba(63, 52, 31, 0.14);
}

.hero-image {
  width: 100%;
  height: 520rpx;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(16, 17, 16, 0.1) 0%, rgba(16, 17, 16, 0.58) 100%);
}

.hero-topbar,
.hero-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  z-index: 2;
}

.hero-topbar {
  top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-type,
.hero-collection,
.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  backdrop-filter: blur(12rpx);
}

.hero-type,
.hero-badge {
  color: #fffaf3;
  background: rgba(255, 255, 255, 0.16);
}

.hero-collection {
  color: #314b38;
  background: rgba(255, 248, 236, 0.88);
}

.hero-copy {
  bottom: 28rpx;
}

.hero-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #fffaf3;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 250, 243, 0.84);
}

.content-stack {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: -48rpx;
  position: relative;
  z-index: 3;
}

.summary-card,
.info-card,
.host-card {
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 252, 246, 0.9);
  border: 1rpx solid rgba(83, 112, 88, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(63, 52, 31, 0.08);
}

.summary-head,
.info-head,
.host-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: rgba(70, 106, 82, 0.56);
}

.summary-title,
.section-title {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  color: var(--text-primary);
}

.summary-status,
.section-tip {
  font-size: 20rpx;
  line-height: 1.4;
  color: var(--text-light);
  text-align: right;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.summary-item {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(244, 239, 231, 0.9);
}

.summary-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-light);
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  color: var(--text-primary);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.detail-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(70, 106, 82, 0.1);
  color: var(--primary-color);
  font-size: 20rpx;
  line-height: 1;
}

.info-content {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: var(--text-secondary);
}

.creator-info {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: rgba(244, 239, 231, 0.82);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.creator-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.creator-name {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.creator-status {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.action-buttons {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 18rpx;
  z-index: 10;
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 245, 0.94);
  border: 1rpx solid rgba(83, 112, 88, 0.08);
  box-shadow: 0 24rpx 52rpx rgba(63, 52, 31, 0.14);
  backdrop-filter: blur(18rpx);
}

.action-buttons .btn {
  flex: 1;
}
