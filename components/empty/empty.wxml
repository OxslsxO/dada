<view class="empty-container" wx:if="{{visible}}">
  <view class="empty-icon">{{icon || '🔍'}}</view>
  <view class="empty-text">{{text || '暂无数据'}}</view>
  <view class="empty-desc">{{desc || ''}}</view>
  <button wx:if="{{btnText}}" class="btn btn-primary mt-2" bindtap="handleBtnClick">
    {{btnText}}
  </button>
</view>
