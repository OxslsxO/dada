.tab-item.active .profile-icon {
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="16" r="7" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 40C10 32.268 16.268 26 24 26C31.732 26 38 32.268 38 40" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>');
