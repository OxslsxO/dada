.tab-item.active .home-icon {
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M10 20V38C10 39.1046 10.8954 40 12 40H19V29H29V40H36C37.1046 40 38 39.1046 38 38V20" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 22L22.2764 8.84616C23.2868 8.04061 24.7132 8.04061 25.7236 8.84616L42 22" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>');
}

.tab-item.active .message-icon {
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M40 24C40 32.8366 32.8366 40 24 40C20.6944 40 17.634 38.9781 15.1356 37.235L8 40L10.765 32.8644C9.02187 30.366 8 27.3056 8 24C8 15.1634 15.1634 8 24 8C32.8366 8 40 15.1634 40 24Z" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>');
}

.tab-item.active .profile-icon {
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="16" r="7" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 40C10 32.268 16.268 26 24 26C31.732 26 38 32.268 38 40" stroke="%23466A52" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>');
}

.tab-item.active .tab-icon-shell {
  background: rgba(70, 106, 82, 0.1);
}

.tab-item.active .icon-svg {
  transform: translateY(-1rpx);
  filter: drop-shadow(0 4rpx 8rpx rgba(70, 106, 82, 0.16));
}

.tab-text {
  display: block;
  margin: 0 !important;
  /* 行高设置为与 font-size 相同或略小，彻底消除字体自带的底部空白 */
  font-size: 18rpx !important;
  line-height: 1 !important;    /* 1 = 18rpx，无多余行高空间 */
  font-weight: 500 !important;
  letter-spacing: 0.2rpx;
  color: #8c988f !important;
  transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 激活态保持样式，无需改动 */
.tab-item.active .tab-text {
  color: #466a52 !important;
  font-weight: 600;
}

.tab-item-create {
  justify-content: center !important;
  padding: 0 !important;
}

.create-core {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f4b36f 0%, #df8f49 100%);
  box-shadow:
    0 10rpx 20rpx rgba(223, 143, 73, 0.28),
    0 2rpx 6rpx rgba(223, 143, 73, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item-create:active .create-core {
  transform: scale(0.95);
  box-shadow:
    0 6rpx 14rpx rgba(223, 143, 73, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.create-plus {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.create-plus::before,
.create-plus::after {
  content: '';
  position: absolute;
  background: #ffffff;
  border-radius: 2rpx;
}

.create-plus::before {
  left: 50%;
  top: 2rpx;
  bottom: 2rpx;
  width: 4rpx;
  transform: translateX(-50%);
}

.create-plus::after {
  top: 50%;
  left: 2rpx;
  right: 2rpx;
  height: 4rpx;
  transform: translateY(-50%);
}

.create-text {
  margin-top: 6rpx !important;
  color: #c67e3b !important;
}
