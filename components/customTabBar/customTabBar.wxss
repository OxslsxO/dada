.tab-item.active .icon-svg {
  transform: translateY(-2rpx);
  filter: drop-shadow(0 4rpx 8rpx rgba(70, 106, 82, 0.25));
}

.tab-text {
  font-size: 20rpx !important;
  line-height: 1 !important;
  font-weight: 500 !important;
  color: #8c988f !important;
  margin-top: 36rpx !important; 
  margin-bottom: 6rpx !important; 
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
  position: relative !important;
  top: 0 !important; 
}

.tab-item.active .tab-text {
  color: #466a52;
  font-weight: 600;
}

.create-item {
  position: relative;
  margin-top: -20rpx;
}

.create-core {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f4b36f 0%, #df8f49 100%);
  box-shadow:
    0 8rpx 24rpx rgba(223, 143, 73, 0.35),
    0 2rpx 6rpx rgba(223, 143, 73, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.create-item:active .create-core {
  transform: scale(0.92);
  box-shadow:
    0 4rpx 12rpx rgba(223, 143, 73, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.create-plus {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.create-plus::before,
.create-plus::after {
  content: '';
  position: absolute;
  background: white;
  border-radius: 2rpx;
}

.create-plus::before {
  left: 50%;
  top: 4rpx;
  bottom: 4rpx;
  width: 4rpx;
  transform: translateX(-50%);
}

.create-plus::after {
  top: 50%;
  left: 4rpx;
  right: 4rpx;
  height: 4rpx;
  transform: translateY(-50%);
}