.custom-tab-bar {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 28rpx;
  z-index: 999;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  align-items: stretch;
  column-gap: 8rpx;
  min-height: 92rpx;
  /* 重点：把底部内边距压到最小！！！你之前留白全是这里撑的 */
  padding: 10rpx 16rpx 0 !important;
  padding-bottom: calc(env(safe-area-inset-bottom) * 0.5) !important;
  border-radius: 30rpx;
  background: rgba(255, 251, 245, 0.96);
  box-shadow:
    0 16rpx 36rpx rgba(76, 64, 39, 0.1),
    0 3rpx 10rpx rgba(76, 64, 39, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(24rpx);
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end; /* 内容整体靠底部 */
  height: 100%; /* 继承grid高度 */
  min-height: auto;
  padding: 0 0 6rpx !important; /* 底部留一点间距，不贴死 */
  margin: 0 !important;
  box-sizing: border-box;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item:active {
  transform: scale(0.96);
}

.tab-icon-shell {
  width: 56rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;  /* 从 6rpx 稍微减少，让文字更紧凑（可选） */
  border-radius: 20rpx;
  transition: background 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.icon-svg {
  width: 34rpx;
  height: 34rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

