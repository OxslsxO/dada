.custom-tab-bar {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: 40rpx;
  z-index: 999;
  height: 100rpx;
  padding: 8rpx 16rpx calc(env(safe-area-inset-bottom) + 8rpx);
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-radius: 50rpx;
  background: rgba(255, 252, 247, 0.95);
  box-shadow:
    0 12rpx 40rpx rgba(76, 64, 39, 0.12),
    0 2rpx 8rpx rgba(76, 64, 39, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(24rpx);
  box-sizing: border-box;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  padding: 0 !important; 
  margin: 0 !important;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-item:active {
  transform: scale(0.92);
}


.icon-wrap {
  margin-bottom: 0 !important; 
  flex-shrink: 0; 
}

.icon-svg {
  width: 40rpx;
  height: 40rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

